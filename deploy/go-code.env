# go-code environment configuration template.
# Copy to .env (or reference from docker-compose) and fill in real values.
# NEVER commit a file with real secrets.

# MCP HTTP server port (default: 8897).
MCP_PORT=8897

# LLM proxy (CLIProxyAPI at :8317).
LLM_API_BASE=http://127.0.0.1:8317/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-3.1-flash-lite-preview

# GitHub token for authenticated clones and higher API rate limits (5000/hr vs 60/hr).
# Needed for private repos. Strongly recommended for production.
GITHUB_TOKEN=your_github_token_here

# Workspace directory for temporary repository clones.
# Should be a fast local disk with enough space (e.g. /tmp or a dedicated volume).
WORKSPACE_DIR=/tmp/go-code-workspace

# Maximum file size to parse (kilobytes). Files larger than this are skipped.
# Default: 512 KB.
MAX_FILE_KB=512

# Maximum total repository size to accept for analysis (megabytes).
# Prevents OOM on very large monorepos.
# Default: 200 MB.
MAX_REPO_MB=200
